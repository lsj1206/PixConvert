<UserControl x:Class="PixConvert.Views.Dialogs.ConfirmationWarningContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel Margin="0,4,0,0">
        <TextBlock
            FontSize="14"
            Text="{Binding Message, ElementName=Root}"
            TextWrapping="Wrap" />
        <TextBlock
            Margin="0,12,0,0"
            FontFamily="Segoe UI Emoji, Segoe UI"
            FontSize="12"
            Foreground="{DynamicResource AppWarningForegroundBrush}"
            Text="{Binding WarningMessage, ElementName=Root}"
            TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
