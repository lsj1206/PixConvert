<Window x:Class="PixConvert.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:layouts="clr-namespace:PixConvert.Views.Layouts"
        xmlns:lists="clr-namespace:PixConvert.Views.Lists"
        xmlns:viewModels="clr-namespace:PixConvert.ViewModels"
        xmlns:converters="clr-namespace:PixConvert.Converters"
        xmlns:ui="http://schemas.modernwpf.com/2019"
    mc:Ignorable="d"
    Title="{DynamicResource App_Title}"
    Width="960"
    Height="600"
    MinWidth="720"
    MinHeight="540"
    ui:WindowHelper.UseModernWindowStyle="True"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:MultiStatusVisibilityConverter x:Key="MultiStatusVisibilityConverter" />
    </Window.Resources>

    <!-- Window : Root_Grid -->
    <Grid>
        <Grid.RowDefinitions>
            <!-- Window : Header_Row -->
            <RowDefinition Height="36" />
            <!-- Window : Main_Content_Row -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Window : Header_Section -->
        <layouts:HeaderControl Grid.Row="0" />

        <!-- Window : Main_Section -->
        <Grid
            Grid.Row="1"
            Margin="6">
            <Grid.ColumnDefinitions>
                <!-- Window : Sidebar_Column -->
                <ColumnDefinition Width="Auto" />
                <!-- Window : FileList_Column -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Window : Sidebar_Section -->
            <layouts:SidebarControl Grid.Column="0" />

            <!-- Window : FileList_Section -->
            <lists:FileListControl
                Grid.Column="1"
                Margin="6,0,0,0"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderDefaultBrush}"
                BorderThickness="1"
                DataContext="{Binding FileList}"
                DeleteSelectedCommand="{Binding DataContext.ListManager.DeleteFilesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                DropFilesCommand="{Binding DataContext.FileInput.DropFilesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                IsMismatchFilterActive="{Binding DataContext.SortFilter.ShowMismatchOnly, RelativeSource={RelativeSource AncestorType=Window}}"
                MoveItemsCommand="{Binding DataContext.FileList.MoveItemsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                SortByColumnCommand="{Binding DataContext.SortFilter.SortByColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                Visibility="{Binding CurrentStatus, Converter={StaticResource MultiStatusVisibilityConverter}, ConverterParameter=!Converting}" />

            <!-- Window : Converting_List_Section -->
            <lists:ConvertingListControl
                Grid.Column="1"
                Margin="6,0,0,0"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderDefaultBrush}"
                BorderThickness="1"
                DataContext="{Binding Conversion}"
                Visibility="{Binding CurrentStatus, Converter={StaticResource MultiStatusVisibilityConverter}, ConverterParameter=Converting}" />
        </Grid>

        <!-- Window : Snackbar_Overlay -->
        <layouts:SnackbarControl
            Grid.Row="0"
            Grid.RowSpan="2"
            DataContext="{Binding Snackbar}" />
    </Grid>
</Window>
