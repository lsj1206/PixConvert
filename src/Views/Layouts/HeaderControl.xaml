<UserControl x:Class="PixConvert.Views.Layouts.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:local="clr-namespace:PixConvert"
             mc:Ignorable="d">

    <!-- Header : Main_Container -->
    <Border
        Padding="10,5"
        Background="{DynamicResource AppSurfaceBrush}"
        BorderBrush="{DynamicResource AppBorderDefaultBrush}"
        BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="186" /> <!-- Header : Left_Space -->
                <ColumnDefinition Width="240" /> <!-- Header : Status_Dashboard -->
                <ColumnDefinition Width="*" />   <!-- Header : Resource_Dashboard -->
                <ColumnDefinition Width="Auto" /> <!-- Header : Version_Info -->
            </Grid.ColumnDefinitions>

            <!-- Header : Status_Dashboard_Group -->
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <!-- Header : Total_Status -->
                <StackPanel
                    Margin="0,0,32,0"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource AppTextSecondaryBrush}"
                        Text="{DynamicResource Status_Total}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimaryBrush}"
                        Text="{Binding Header.TotalCount}" />
                </StackPanel>
                <!-- Header : Unknown_Status -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource AppTextSecondaryBrush}"
                        Text="{DynamicResource Status_Unknown}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppDangerBrush}"
                        Text="{Binding Header.UnsupportedCount}" />
                </StackPanel>
            </StackPanel>

            <!-- Header : Resource_Dashboard_Group -->
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <!-- Header : Resource_Indicators -->
                <StackPanel
                    Margin="80,0,0,0"
                    Orientation="Horizontal">
                    <!-- Header : Cpu_Usage -->
                    <StackPanel
                        Margin="0,0,32,0"
                        Orientation="Horizontal">
                        <ui:FontIcon
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="{DynamicResource AppAccentBrush}"
                            Glyph="&#xE950;" />
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="{DynamicResource AppTextSecondaryBrush}"
                            Text="{DynamicResource Header_Label_Cpu}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="Bold"
                            Text="{Binding Header.CpuUsageText}" />
                    </StackPanel>

                    <!-- Header : Ram_Usage -->
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource AppAccentBrush}"
                            Glyph="&#xE964;" />
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="{DynamicResource AppTextSecondaryBrush}"
                            Text="{DynamicResource Header_Label_Ram}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="{Binding Header.MemoryUsageText}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Header : Utilities_Group -->
            <StackPanel
                Grid.Column="3"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <!-- Header : Version_Text -->
                <TextBlock
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Normal"
                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                    Text="{x:Static local:App.Version}" />

                <!-- Header : Settings_Button -->
                <Button
                    Margin="0"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding Header.ShowAppSettingCommand}">
                    <ui:FontIcon
                        FontSize="16"
                        Foreground="{DynamicResource AppAccentBrush}"
                        Glyph="&#xE713;" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
