<UserControl x:Class="PixConvert.Views.Layouts.SnackbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:PixConvert.Services"
    mc:Ignorable="d"
    Margin="0"
    HorizontalAlignment="Center"
    VerticalAlignment="Top">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Snackbar : Type_Background_Style -->
        <Style
            x:Key="SnackbarBorderStyle"
            TargetType="Border">
            <Setter Property="Background" Value="#0078D4" /> <!-- Default Dark -->
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="MaxWidth" Value="600" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.3"
                        ShadowDepth="2" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Snackbar : Success_Trigger -->
                <DataTrigger
                    Binding="{Binding Type}"
                    Value="{x:Static services:SnackbarType.Success}">
                    <Setter Property="Background" Value="#107C10" />
                </DataTrigger>
                <!-- Snackbar : Warning_Trigger -->
                <DataTrigger
                    Binding="{Binding Type}"
                    Value="{x:Static services:SnackbarType.Warning}">
                    <Setter Property="Background" Value="#C19C00" />
                </DataTrigger>
                <!-- Snackbar : Error_Trigger -->
                <DataTrigger
                    Binding="{Binding Type}"
                    Value="{x:Static services:SnackbarType.Error}">
                    <Setter Property="Background" Value="#C42B1C" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Snackbar : Main_Container -->
    <Border
        x:Name="MainBorder"
        Style="{StaticResource SnackbarBorderStyle}"
        Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border.RenderTransform>
            <TranslateTransform Y="-50" />
        </Border.RenderTransform>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="CommonStates">
                <!-- Snackbar : State_Hidden -->
                <VisualState x:Name="Hidden">
                    <Storyboard>
                        <DoubleAnimation
                            Duration="0:0:0.3"
                            Storyboard.TargetName="MainBorder"
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                            To="-50">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseIn" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Duration="0:0:0.3"
                            Storyboard.TargetName="MainBorder"
                            Storyboard.TargetProperty="Opacity"
                            To="0" />
                    </Storyboard>
                </VisualState>
                <!-- Snackbar : State_Visible -->
                <VisualState x:Name="Visible">
                    <Storyboard>
                        <DoubleAnimation
                            Duration="0:0:0.4"
                            Storyboard.TargetName="MainBorder"
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                            To="0">
                            <DoubleAnimation.EasingFunction>
                                <BackEase
                                    Amplitude="0.5"
                                    EasingMode="EaseOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Duration="0:0:0.3"
                            Storyboard.TargetName="MainBorder"
                            Storyboard.TargetProperty="Opacity"
                            To="1" />
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Snackbar : Message_Content -->
        <TextBlock
            VerticalAlignment="Center"
            FontSize="14"
            FontWeight="SemiBold"
            Foreground="White"
            Text="{Binding Message}"
            TextAlignment="Center" />
    </Border>
</UserControl>
