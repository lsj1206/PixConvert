<UserControl x:Class="PixConvert.Views.Layouts.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:PixConvert.Services"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d">

    <!-- 사이드바 버튼 스타일 정의 -->
    <UserControl.Resources>
        <!-- Sidebar : Button_Style -->
        <Style
            x:Key="SidebarButtonStyle"
            TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtleBrush}" />
        </Style>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="UserControl">
            <!-- Sidebar : Default_Width -->
            <Setter Property="Width" Value="180" />
            <Style.Triggers>
                <!-- Sidebar : Width_Expansion_Trigger -->
                <DataTrigger
                    Binding="{Binding CurrentStatus}"
                    Value="">
                    <Setter Property="Width" Value="360" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <!-- Sidebar : Main_Layout -->
    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        PanningMode="VerticalOnly"
        VerticalScrollBarVisibility="Hidden">

        <Border
            Margin="0"
            Padding="12"
            Background="{DynamicResource AppSidebarSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8">

            <ContentControl Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical">
                                        <!-- Sidebar : File_Operations_Group -->
                                        <Button
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Content="{DynamicResource Btn_AddFile}"
                                            Command="{Binding FileInput.AddFilesCommand}" />
                                        <Button
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Content="{DynamicResource Btn_AddFolder}"
                                            Command="{Binding FileInput.AddFolderCommand}" />

                                        <Separator Margin="0,0,0,8" />

                                        <!-- Sidebar : ActivePreset_Info -->
                                        <TextBlock
                                            Margin="0,0,0,6"
                                            HorizontalAlignment="Center"
                                            FontWeight="SemiBold"
                                            TextTrimming="CharacterEllipsis"
                                            Text="{Binding Conversion.ActivePresetName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Conversion.IsActivePresetValid}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDangerBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Sidebar : Conversion_Group -->
                                        <Button
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Content="{DynamicResource Btn_ConvertSetting}"
                                            Command="{Binding Conversion.OpenConvertSettingCommand}" />
                                        <Button
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Foreground="{DynamicResource AppAccentBrush}"
                                            Content="{DynamicResource Btn_Convert}"
                                            Command="{Binding Conversion.ConvertFilesCommand}" />

                                        <Separator Margin="0,0,0,8" />

                                        <!-- Sidebar : ListManager_Group -->
                                        <Button
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Content="{DynamicResource Btn_ListManager}"
                                            Command="{Binding ListManager.EnterListManagerCommand}" />

                                        <!-- Sidebar : Sorting_Group -->
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock
                                                Margin="0,0,0,4"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimaryBrush}"
                                                Text="{DynamicResource Sort_Label}" />

                                            <!-- Sidebar : Sort_Selection -->
                                            <ComboBox
                                                Margin="0,0,0,2"
                                                HorizontalAlignment="Stretch"
                                                SelectedValue="{Binding SortFilter.SelectedSortType, Mode=TwoWay}"
                                                SelectedValuePath="Tag">
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Index}"
                                                    Tag="{x:Static services:SortType.AddIndex}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_NameIndex}"
                                                    Tag="{x:Static services:SortType.NameIndex}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_NamePath}"
                                                    Tag="{x:Static services:SortType.NamePath}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_PathIndex}"
                                                    Tag="{x:Static services:SortType.PathIndex}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_PathName}"
                                                    Tag="{x:Static services:SortType.PathName}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Size}"
                                                    Tag="{x:Static services:SortType.Size}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Extension}"
                                                    Tag="{x:Static services:SortType.Extension}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Signature}"
                                                    Tag="{x:Static services:SortType.Signature}" />
                                            </ComboBox>

                                            <!-- Sidebar : Filter_Options -->
                                            <ui:ToggleSwitch
                                                OffContent="{DynamicResource Sort_Desc}"
                                                OnContent="{DynamicResource Sort_Asc}"
                                                IsOn="{Binding SortFilter.IsSortAscending}" />
                                            <ui:ToggleSwitch
                                                Margin="0,0,0,4"
                                                OffContent="{DynamicResource Option_MismatchOnly}"
                                                OnContent="{DynamicResource Option_MismatchOnly}"
                                                ToolTip="{DynamicResource Tip_MismatchOnly}"
                                                IsOn="{Binding SortFilter.ShowMismatchOnly}" />
                                            <Button
                                                Style="{StaticResource SidebarButtonStyle}"
                                                Content="{DynamicResource Btn_ReorderIndex}"
                                                Command="{Binding SortFilter.ReorderNumberCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <!-- Sidebar : Trigger_Converting -->
                            <DataTrigger
                                Binding="{Binding CurrentStatus}"
                                Value="Converting">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <StackPanel Orientation="Vertical">
                                                <!-- Sidebar : Converting_Status -->
                                                <Button>
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                                            <Setter Property="Content" Value="{DynamicResource Btn_Cancel}" />
                                                            <Setter Property="Command" Value="{Binding Conversion.CancelConvertCommand}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDangerBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Conversion.IsConversionCompleted}" Value="True">
                                                                    <Setter Property="Content" Value="{DynamicResource Dlg_Confirm}" />
                                                                    <Setter Property="Command" Value="{Binding Conversion.ConfirmCompletionCommand}" />
                                                                    <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppAccentForegroundBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Separator Margin="0,0,0,6" />

                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppAccentBrush}"
                                                    Text="{DynamicResource Converting_Title}" />

                                                <!-- Sidebar : Converting_Details -->
                                                <TextBlock
                                                    Margin="0,-10,0,2"
                                                    TextAlignment="Right"
                                                    FontSize="12"
                                                    FontWeight="Medium"
                                                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                    Text="{Binding Conversion.ConvertingTime}" />
                                                <ProgressBar Margin="0"
                                                             Padding="0"
                                                             Height="8"
                                                             MinHeight="0"
                                                             VerticalAlignment="Stretch"
                                                             Maximum="100"
                                                             Minimum="0"
                                                             Value="{Binding Conversion.ConvertProgressPercent}" />
                                                <TextBlock
                                                    TextAlignment="Right">
                                                    <Run
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimaryBrush}"
                                                        Text="{Binding Conversion.ProcessedCount}" />
                                                    <Run Foreground="{DynamicResource AppTextSecondaryBrush}" Text="/" />
                                                    <Run Foreground="{DynamicResource AppTextSecondaryBrush}" Text="{Binding Conversion.TotalConvertCount}" />
                                                </TextBlock>

                                                <TextBlock
                                                    Margin="0,0,0,6"
                                                    TextAlignment="Right"
                                                    Foreground="{DynamicResource AppDangerBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding Conversion.HasFailures}"
                                                                    Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="{DynamicResource Converting_FailCount}" />
                                                    <Run Text=":" />
                                                    <Run FontWeight="SemiBold" Text="{Binding Conversion.FailCount}" />
                                                </TextBlock>

                                                <Separator Margin="0,0,0,6" />

                                                <!-- Sidebar : Options Info (Extended) -->
                                                <TextBlock
                                                    Margin="0,0,0,2"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                    Text="{DynamicResource Converting_Cpu}" />
                                                <TextBlock
                                                    Margin="8,0,0,2"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Conversion.CurrentCpuUsage}" />

                                                <TextBlock
                                                    Margin="0,0,0,2"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                    Text="{DynamicResource Converting_Duplicates}" />
                                                <TextBlock
                                                    Margin="8,0,0,2"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Conversion.CurrentOverwritePolicy}" />

                                                <TextBlock
                                                    Margin="0,0,0,2"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                    Text="{DynamicResource Converting_SaveMethod}" />
                                                <TextBlock
                                                    Margin="8,0,0,2"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Conversion.CurrentSaveMethod}" />

                                                <TextBlock
                                                    Margin="0,0,0,2"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                    Text="{DynamicResource Converting_SaveLocation}" />
                                                <TextBlock
                                                    Margin="8,0,0,2"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    TextTrimming="CharacterEllipsis"
                                                    Text="{Binding Conversion.CurrentSaveLocation}"
                                                    ToolTip="{Binding Conversion.CurrentSaveLocationTooltip}" />

                                                <Separator Margin="0,6,0,6" />

                                                <TextBlock
                                                    Margin="0,0,0,2"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                    Text="{DynamicResource Converting_Format}" />
                                                <TextBlock
                                                    Margin="8,0,0,2"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Conversion.CurrentTargetFormat}" />

                                                <StackPanel Visibility="{Binding Conversion.ShowCurrentStandardOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Margin="0,0,0,2"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                               Text="{DynamicResource Converting_StandardOptions}"/>
                                                    <TextBlock Margin="8,0,0,2"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding Conversion.CurrentStandardOptions}"/>
                                                </StackPanel>

                                                <StackPanel Visibility="{Binding Conversion.ShowCurrentAnimationOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Margin="0,0,0,2"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                               Text="{DynamicResource Converting_AnimationOptions}"/>
                                                    <TextBlock Margin="8,0,0,2"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding Conversion.CurrentAnimationOptions}"/>
                                                </StackPanel>

                                            </StackPanel>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <!-- Sidebar : Trigger_ListManager -->
                            <DataTrigger
                                Binding="{Binding CurrentStatus}"
                                Value="ListManager">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <StackPanel Orientation="Vertical">
                                                <!-- Sidebar : Back_Button -->
                                                <Button
                                                    Style="{StaticResource SidebarButtonStyle}"
                                                    Content="{DynamicResource Btn_Back}"
                                                    Command="{Binding ListManager.ExitListManagerCommand}" />
                                                <!-- Sidebar : Clear_All -->
                                                <Button
                                                    Style="{StaticResource SidebarButtonStyle}"
                                                    Foreground="{DynamicResource AppDangerBrush}"
                                                    Content="{DynamicResource Btn_ListClear}"
                                                    Command="{Binding ListManager.RemoveAllListCommand}" />

                                                <Separator Margin="0,0,0,8" />

                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppAccentBrush}"
                                                    Text="{DynamicResource ListManager_Title}" />

                                                <TextBlock
                                                    Margin="0,0,0,8"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                    Text="{DynamicResource ListManager_Desc}"
                                                    TextWrapping="Wrap" />

                                                <!-- Sidebar : Extension_Tags_Group -->
                                                <ItemsControl
                                                    MinHeight="60"
                                                    Margin="0"
                                                    ItemsSource="{Binding ListManager.FormatTags}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <ToggleButton
                                                                Margin="0,0,4,4"
                                                                Padding="8,4"
                                                                FontSize="11"
                                                                Content="{Binding Format}"
                                                                IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Sidebar : List_Cleaning_Options -->
                                                <CheckBox
                                                    Margin="0,0,0,8"
                                                    Content="{DynamicResource ListManager_Unsupported}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppDangerBrush}"
                                                    IsChecked="{Binding ListManager.RemoveUnsupported, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                <Button
                                                    Margin="0,0,0,4"
                                                    Style="{StaticResource SidebarButtonStyle}"
                                                    Content="{DynamicResource Btn_ClearSelected}"
                                                    Command="{Binding ListManager.ClearSelectedCommand}" />

                                            </StackPanel>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Border>
    </ScrollViewer>
</UserControl>
