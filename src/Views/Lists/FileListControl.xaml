<UserControl x:Class="PixConvert.Views.Lists.FileListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PixConvert.Models"
             xmlns:converters="clr-namespace:PixConvert.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Converters -->
        <converters:FileSizeConverter x:Key="FileSizeConverter" />

        <!-- FileList : Item_Brushes -->
        <SolidColorBrush x:Key="ItemHoverBackground" Color="#E5F3FF" />
        <SolidColorBrush x:Key="ItemSelectedBackground" Color="#CCE8FF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#666666" />
        <SolidColorBrush x:Key="AccentColor" Color="#0078D4" />

        <!-- FileList : Item_ContainerStyle -->
        <Style
            x:Key="FileItemContainerStyle"
            TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="4,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <!-- FileList : Item_Template -->
                    <ControlTemplate TargetType="ListViewItem">
                        <Border
                            x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                            <GridViewRowPresenter
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemSelectedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ListView
            x:Name="FileListView"
            Padding="0,0,12,16"
            AllowDrop="True"
            Background="Transparent"
            BorderThickness="0"
            DragLeave="FileListView_DragLeave"
            Drop="FileListView_Drop"
            GridViewColumnHeader.Click="Header_Click"
            ItemContainerStyle="{StaticResource FileItemContainerStyle}"
            ItemsSource="{Binding Items}"
            KeyDown="ListView_KeyDown"
            MouseMove="FileListView_MouseMove"
            PreviewDragOver="FileListView_PreviewDragOver"
            PreviewMouseLeftButtonDown="FileListView_PreviewMouseLeftButtonDown"
            PreviewMouseLeftButtonUp="FileListView_PreviewMouseLeftButtonUp"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            SelectionMode="Extended"
            VirtualizingPanel.CacheLength="20,20"
            VirtualizingPanel.CacheLengthUnit="Item"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
                <!-- FileList : GridView_Main -->
                <GridView>
                    <GridView.ColumnHeaderContainerStyle>
                        <!-- FileList : Header_Style -->
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                            <Setter Property="Padding" Value="10,5" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </GridView.ColumnHeaderContainerStyle>

                    <!-- FileList : Column_Index -->
                    <GridViewColumn Width="60">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader
                                Content="{DynamicResource List_Index}"
                                Tag="AddIndex" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    Foreground="{DynamicResource TextSecondary}"
                                    Text="{Binding AddIndex}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- FileList : Column_Name -->
                    <GridViewColumn Width="250">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader
                                Content="{DynamicResource List_Name}"
                                Tag="NameIndex" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- FileList : Name_Text -->
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center" />

                                    <!-- FileList : Animation_Badge -->
                                    <Border
                                        Grid.Column="1"
                                        Margin="6,0,0,0"
                                        Padding="4,1"
                                        VerticalAlignment="Center"
                                        Background="#E1BEE7"
                                        CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnimation}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            FontSize="9"
                                            FontWeight="Bold"
                                            Foreground="#6A1B9A"
                                            Text="ANI" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- FileList : Column_Extension -->
                    <GridViewColumn Width="62">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader
                                Content="{DynamicResource List_Extension}"
                                Tag="Extension" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Foreground="{DynamicResource TextSecondary}"
                                    Text="{Binding Extension}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- FileList : Column_Signature -->
                    <GridViewColumn Width="68">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader
                                Content="{DynamicResource List_Signature}"
                                Tag="Signature" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileSignature}">
                                    <TextBlock.Style>
                                        <Style
                                            BasedOn="{StaticResource {x:Type TextBlock}}"
                                            TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                            <Style.Triggers>
                                                <!-- FileList : Signature_Mismatch_Trigger -->
                                                <DataTrigger
                                                    Binding="{Binding IsMismatch}"
                                                    Value="True">
                                                    <Setter Property="Foreground" Value="#FF4444" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- FileList : Column_Size -->
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader
                                Content="{DynamicResource List_Size}"
                                Tag="Size" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Foreground="{DynamicResource TextSecondary}"
                                    Text="{Binding Size, Converter={StaticResource FileSizeConverter}}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- FileList : Column_Path -->
                    <GridViewColumn Width="300">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader
                                Content="{DynamicResource List_Path}"
                                Tag="PathIndex" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Foreground="#999999"
                                    Text="{Binding Directory}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTip="{Binding Path}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- FileList : Drag_Drop_Indicator -->
        <Canvas
            x:Name="DragAdornerCanvas"
            IsHitTestVisible="False">
            <Border
                x:Name="DropIndicator"
                Width="{Binding ActualWidth, ElementName=FileListView}"
                Height="1"
                CornerRadius="1.5"
                HorizontalAlignment="Stretch"
                Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="4"
                        Opacity="0.6"
                        ShadowDepth="0"
                        Color="#0078D4" />
                </Border.Effect>
                <Border.Background>
                    <LinearGradientBrush
                        StartPoint="0,0.5"
                        EndPoint="1,0.5">
                        <GradientStop
                            Offset="0"
                            Color="#0078D4" />
                        <GradientStop
                            Offset="0.85"
                            Color="#0078D4" />
                        <GradientStop
                            Offset="1"
                            Color="Transparent" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
