<UserControl x:Class="PixConvert.Views.Lists.ConvertingListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:PixConvert.Models"
             xmlns:converters="clr-namespace:PixConvert.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Converter for Status Text -->
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:SizeRatioConverter x:Key="SizeRatioConverter" />
        <converters:SizeRatioStateConverter x:Key="SizeRatioStateConverter" />

        <!-- FileList : Item_ContainerStyle -->
        <Style x:Key="FileItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="4,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                            <GridViewRowPresenter
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AppListItemHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AppListItemSelectedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <CollectionViewSource x:Key="FilteredItems" Source="{Binding Items}" Filter="CollectionViewSource_Filter" />
    </UserControl.Resources>

    <Grid>
        <ListView
            x:Name="ConvertingListView"
            Padding="0,0,12,16"
            Background="Transparent"
            BorderThickness="0"
            ItemContainerStyle="{StaticResource FileItemContainerStyle}"
            ItemsSource="{Binding Source={StaticResource FilteredItems}}"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            VirtualizingPanel.CacheLength="20,20"
            VirtualizingPanel.CacheLengthUnit="Item"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
                <GridView>
                    <GridView.ColumnHeaderContainerStyle>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
                            <Setter Property="Padding" Value="10,5" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </GridView.ColumnHeaderContainerStyle>

                    <!-- Column : Index -->
                    <GridViewColumn Width="60" >
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Index}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                                    Text="{Binding AddIndex}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Source Name -->
                    <GridViewColumn Width="200">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Name}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        TextTrimming="CharacterEllipsis">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}.{1}">
                                                <Binding Path="Name" />
                                                <Binding Path="Extension" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <Border
                                        Grid.Column="1"
                                        Margin="6,0,0,0"
                                        Padding="4,1"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource AppAnimationBadgeBackgroundBrush}"
                                        CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnimation}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            FontSize="9"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource AppAnimationBadgeForegroundBrush}"
                                            Text="ANI" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Source Format -->
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Signature}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{DynamicResource AppTextSecondaryBrush}" Text="{Binding FileSignature}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Size (Original) -->
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Size}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{DynamicResource AppTextSecondaryBrush}" Text="{Binding Size, Converter={StaticResource FileSizeConverter}}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Progress -->
                    <GridViewColumn Width="150">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Progress}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="-6,0" VerticalAlignment="Stretch">
                                    <ProgressBar
                                        x:Name="StatusProgressBar"
                                        VerticalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{DynamicResource AppProgressIdleBrush}"
                                        IsHitTestVisible="False"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="{Binding Progress}" />

                                    <StackPanel
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <!-- Indicator : Red Dot (Visible during Processing) -->
                                        <Ellipse
                                            x:Name="ProcessingIndicator"
                                            Width="6" Height="6"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed"
                                            Fill="{DynamicResource AppDangerBrush}" />

                                        <TextBlock
                                            x:Name="StatusLabel"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextSecondaryBrush}"
                                            Text="{DynamicResource Status_Pending}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock
                                        x:Name="SuccessLinkLabel"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis"
                                        Visibility="Collapsed">
                                        <Hyperlink Click="Hyperlink_Click" TextDecorations="Underline" Foreground="{DynamicResource AppSuccessLinkBrush}">
                                            <Run Text="{Binding OutputName, Mode=OneWay}" />
                                        </Hyperlink>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <!-- Processing State -->
                                    <DataTrigger Binding="{Binding Status}" Value="Processing">
                                        <Setter TargetName="StatusProgressBar" Property="Foreground" Value="{DynamicResource AppProgressProcessingBrush}" />
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="{DynamicResource AppSuccessForegroundBrush}" />
                                        <Setter TargetName="StatusLabel" Property="Text" Value="{DynamicResource Status_Processing}" />
                                        <Setter TargetName="ProcessingIndicator" Property="Visibility" Value="Visible" />
                                    </DataTrigger>

                                    <!-- Success State -->
                                    <DataTrigger Binding="{Binding Status}" Value="Success">
                                        <Setter TargetName="StatusProgressBar" Property="Foreground" Value="{DynamicResource AppProgressSuccessBrush}" />
                                        <Setter TargetName="StatusLabel" Property="Text" Value="{DynamicResource Status_Success}" />
                                        <Setter TargetName="StatusLabel" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="SuccessLinkLabel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>

                                    <!-- Error State -->
                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                        <Setter TargetName="StatusProgressBar" Property="Foreground" Value="{DynamicResource AppProgressWarningBrush}" />
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="{DynamicResource AppWarningForegroundBrush}" />
                                        <Setter TargetName="StatusLabel" Property="Text" Value="{DynamicResource Status_Error}" />
                                    </DataTrigger>

                                    <!-- Skipped State -->
                                    <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                        <Setter TargetName="StatusLabel" Property="Text" Value="{DynamicResource Status_Skipped}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Resized -->
                    <GridViewColumn Width="120">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Resized}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid
                                    x:Name="ResizedContainer"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{DynamicResource AppTextSecondaryBrush}"
                                        Text="{Binding OutputSize, Converter={StaticResource FileSizeConverter}}" />

                                    <Border
                                        x:Name="RatioBadge"
                                        Grid.Column="1"
                                        Margin="6,0,0,0"
                                        Padding="4,1"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        CornerRadius="4">
                                        <TextBlock
                                            x:Name="RatioText"
                                            FontSize="9"
                                            FontWeight="Bold">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource SizeRatioConverter}">
                                                    <Binding Path="Size" />
                                                    <Binding Path="OutputSize" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Success">
                                        <Setter TargetName="ResizedContainer" Property="Visibility" Value="Visible" />
                                    </DataTrigger>

                                    <!-- Ratio Status Triggers -->
                                    <DataTrigger Value="Success">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource SizeRatioStateConverter}">
                                                <Binding Path="Size" />
                                                <Binding Path="OutputSize" />
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter TargetName="RatioBadge" Property="Background" Value="{DynamicResource AppSuccessBadgeBackgroundBrush}" />
                                        <Setter TargetName="RatioText" Property="Foreground" Value="{DynamicResource AppSuccessForegroundBrush}" />
                                    </DataTrigger>

                                    <DataTrigger Value="Warning">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource SizeRatioStateConverter}">
                                                <Binding Path="Size" />
                                                <Binding Path="OutputSize" />
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter TargetName="RatioBadge" Property="Background" Value="{DynamicResource AppWarningBadgeBackgroundBrush}" />
                                        <Setter TargetName="RatioText" Property="Foreground" Value="{DynamicResource AppWarningBadgeForegroundBrush}" />
                                    </DataTrigger>

                                    <DataTrigger Value="Error">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource SizeRatioStateConverter}">
                                                <Binding Path="Size" />
                                                <Binding Path="OutputSize" />
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter TargetName="RatioBadge" Property="Background" Value="{DynamicResource AppErrorBackgroundBrush}" />
                                        <Setter TargetName="RatioText" Property="Foreground" Value="{DynamicResource AppErrorForegroundBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Engine -->
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Engine}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="Medium"
                                    TextAlignment="Center"
                                    Foreground="{DynamicResource AppTextSecondaryBrush}"
                                    Text="{Binding ProcessingEngine}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
