<UserControl x:Class="PixConvert.Views.Lists.ConvertingListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:PixConvert.Models"
             xmlns:converters="clr-namespace:PixConvert.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- FileList : Item_Brushes -->
        <SolidColorBrush x:Key="ItemHoverBackground" Color="#E5F3FF" />
        <SolidColorBrush x:Key="ItemSelectedBackground" Color="#CCE8FF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#666666" />
        <SolidColorBrush x:Key="AccentColor" Color="#0078D4" />

        <!-- Converter for Status Text -->
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:SizeRatioConverter x:Key="SizeRatioConverter" />
        <converters:SizeRatioStateConverter x:Key="SizeRatioStateConverter" />

        <!-- FileList : Item_ContainerStyle -->
        <Style x:Key="FileItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="4,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                            <GridViewRowPresenter
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemSelectedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <CollectionViewSource x:Key="FilteredItems" Source="{Binding Items}" Filter="CollectionViewSource_Filter" />
    </UserControl.Resources>

    <Grid>
        <ListView
            x:Name="ConvertingListView"
            Padding="0,0,12,16"
            Background="Transparent"
            BorderThickness="0"
            ItemContainerStyle="{StaticResource FileItemContainerStyle}"
            ItemsSource="{Binding Source={StaticResource FilteredItems}}"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            VirtualizingPanel.CacheLength="20,20"
            VirtualizingPanel.CacheLengthUnit="Item"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
                <GridView>
                    <GridView.ColumnHeaderContainerStyle>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                            <Setter Property="Padding" Value="10,5" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </GridView.ColumnHeaderContainerStyle>

                    <!-- Column : Index -->
                    <GridViewColumn Width="60" >
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Index}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding AddIndex}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Source Name -->
                    <GridViewColumn Width="200">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Name}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}.{1}">
                                                <Binding Path="Name" />
                                                <Binding Path="Extension" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <Border Grid.Column="1" Margin="6,0,0,0" Padding="4,1" VerticalAlignment="Center" Background="#E1BEE7" CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnimation}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="9" FontWeight="Bold" Foreground="#6A1B9A" Text="ANI" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Source Format -->
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Signature}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{DynamicResource TextSecondary}" Text="{Binding FileSignature}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Size (Original) -->
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Size}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{DynamicResource TextSecondary}" Text="{Binding Size, Converter={StaticResource FileSizeConverter}}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Progress -->
                    <GridViewColumn Width="150">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Progress}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="-6,0" VerticalAlignment="Stretch">
                                    <ProgressBar
                                        x:Name="StatusProgressBar"
                                        VerticalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#1A4CAF50"
                                        IsHitTestVisible="False"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="{Binding Progress}" />

                                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <!-- Indicator : Red Dot (Visible during Processing) -->
                                        <Ellipse x:Name="ProcessingIndicator" Width="6" Height="6" Fill="#FF5252" Margin="0,0,8,0" VerticalAlignment="Center" Visibility="Collapsed" />
                                        
                                        <TextBlock
                                            x:Name="StatusLabel"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextSecondary}"
                                            Text="{Binding StatusText}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock
                                        x:Name="SuccessLinkLabel"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis"
                                        Visibility="Collapsed">
                                        <Hyperlink Click="Hyperlink_Click" TextDecorations="Underline" Foreground="#1B5E20">
                                            <Run Text="{Binding OutputName, Mode=OneWay}" />
                                        </Hyperlink>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <!-- Processing State -->
                                    <DataTrigger Binding="{Binding Status}" Value="Processing">
                                        <Setter TargetName="StatusProgressBar" Property="Foreground" Value="#334CAF50" />
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="#2E7D32" />
                                        <Setter TargetName="ProcessingIndicator" Property="Visibility" Value="Visible" />
                                    </DataTrigger>

                                    <!-- Success State -->
                                    <DataTrigger Binding="{Binding Status}" Value="Success">
                                        <Setter TargetName="StatusProgressBar" Property="Foreground" Value="#4D4CAF50" />
                                        <Setter TargetName="StatusLabel" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="SuccessLinkLabel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>

                                    <!-- Error State -->
                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                        <Setter TargetName="StatusProgressBar" Property="Foreground" Value="#4DFFC107" />
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="#F57F17" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Resized -->
                    <GridViewColumn Width="120">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Resized}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid x:Name="ResizedContainer" VerticalAlignment="Center" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="11"
                                               Text="{Binding OutputSize, Converter={StaticResource FileSizeConverter}}"
                                               Foreground="{DynamicResource TextSecondary}" />

                                    <Border x:Name="RatioBadge" Grid.Column="1" Margin="6,0,0,0" Padding="4,1" VerticalAlignment="Center"
                                            HorizontalAlignment="Left" CornerRadius="4">
                                        <TextBlock x:Name="RatioText" FontSize="9" FontWeight="Bold">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource SizeRatioConverter}">
                                                    <Binding Path="Size" />
                                                    <Binding Path="OutputSize" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Success">
                                        <Setter TargetName="ResizedContainer" Property="Visibility" Value="Visible" />
                                    </DataTrigger>

                                    <!-- Ratio Status Triggers -->
                                    <DataTrigger Value="Success">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource SizeRatioStateConverter}">
                                                <Binding Path="Size" />
                                                <Binding Path="OutputSize" />
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter TargetName="RatioBadge" Property="Background" Value="#E8F5E9" />
                                        <Setter TargetName="RatioText" Property="Foreground" Value="#2E7D32" />
                                    </DataTrigger>

                                    <DataTrigger Value="Warning">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource SizeRatioStateConverter}">
                                                <Binding Path="Size" />
                                                <Binding Path="OutputSize" />
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter TargetName="RatioBadge" Property="Background" Value="#FFF3E0" />
                                        <Setter TargetName="RatioText" Property="Foreground" Value="#E65100" />
                                    </DataTrigger>

                                    <DataTrigger Value="Error">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource SizeRatioStateConverter}">
                                                <Binding Path="Size" />
                                                <Binding Path="OutputSize" />
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter TargetName="RatioBadge" Property="Background" Value="#FFEBEE" />
                                        <Setter TargetName="RatioText" Property="Foreground" Value="#C62828" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column : Engine -->
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="{DynamicResource List_Engine}" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                           Text="{Binding ProcessingEngine}" TextAlignment="Center" VerticalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
