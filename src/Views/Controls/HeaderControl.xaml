<UserControl x:Class="PixConvert.Views.Controls.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:local="clr-namespace:PixConvert"
             mc:Ignorable="d">

    <!-- 상단 정보 -->
    <Border Padding="10,5"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="186"/>   <!-- 좌측: 빈공간 -->
                <ColumnDefinition Width="240" />  <!-- 중앙: 상태 대시보드 -->
                <ColumnDefinition Width="*" />    <!-- 중앙: 프로세스 CPU/RAM 사용량 -->
                <ColumnDefinition Width="Auto" /> <!-- 우측: 버전 정보 -->
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

            </StackPanel>

            <!-- 상태 대시보드 -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <!-- 합계 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                    <TextBlock Text="{DynamicResource Status_Total}"
                               FontSize="13"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Header.TotalCount}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <!-- 미지원 -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Status_Unknown}"
                               FontSize="13"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Header.UnsupportedCount}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#FF5555"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <!-- 리소스 대시보드 (앱 리소스 지표) -->
                <StackPanel Orientation="Horizontal" Margin="80,0,0,0">
                    <!-- CPU -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                        <ui:FontIcon Margin="0,0,4,0"
                                     VerticalAlignment="Center"
                                     FontSize="13"
                                     Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                     Glyph="&#xE950;"/>
                        <TextBlock VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Text="CPU" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Text="{Binding Header.CpuUsageText}"/>
                    </StackPanel>

                    <!-- RAM -->
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Margin="0,0,4,0"
                                     VerticalAlignment="Center"
                                     FontSize="12"
                                     Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                     Glyph="&#xE964;"/>
                        <TextBlock VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Text="RAM"/>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="{Binding Header.MemoryUsageText}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- 버전 정보 -->
                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           FontSize="14"
                           FontWeight="Normal"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Text="{x:Static local:App.Version}"/>

                <!-- 설정 버튼 -->
                <Button Margin="0"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Command="{Binding Header.ShowAppSettingCommand}">
                    <ui:FontIcon Glyph="&#xE713;"
                                 FontSize="16"
                                 Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
