<UserControl x:Class="PixConvert.Views.Controls.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:local="clr-namespace:PixConvert"
             mc:Ignorable="d">

    <!-- 상단 정보 -->
    <Border Padding="10,5"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
            BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />   <!-- 좌측: 상태 대시보드 -->
                <ColumnDefinition Width="*" />      <!-- 중앙 공간 -->
                <ColumnDefinition Width="Auto" />   <!-- 우측: 버전 정보 -->
            </Grid.ColumnDefinitions>

            <!-- 상태 대시보드 -->
            <StackPanel Grid.Column="0"
                        Orientation="Vertical"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0">
                <!-- 합계 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <TextBlock Text="{DynamicResource Status_Total}"
                               Width="78"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Header.TotalCount}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <!-- 미지원 -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Status_Unknown}"
                               Width="78"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Header.UnsupportedCount}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#FF5555"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- 구분선 -->
            <Border Grid.Column="0"
                    Width="1"
                    HorizontalAlignment="Right"
                    Margin="0,4"
                    Background="{DynamicResource SystemControlDisabledBaseMediumLowBrush}" />

            <!-- 중앙: 변환 진행 상태 표시 -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Header.CurrentStatus}" Value="Converting">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="{DynamicResource Status_Processing}" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Header.CurrentFileName}" MaxWidth="200" TextTrimming="CharacterEllipsis" ToolTip="{Binding Header.CurrentFileName}" FontWeight="SemiBold" Margin="0,0,16,0" VerticalAlignment="Center"/>

                <!-- 진행률 -->
                <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,4,0" VerticalAlignment="Center">
                    <Run Text="{Binding Header.ProcessedCount}" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" FontWeight="SemiBold"/>
                    <Run Text="/" />
                    <Run Text="{Binding Header.TotalConvertCount}" />
                </TextBlock>

                <!-- 실패 -->
                <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="16,0,4,0" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Header.HasFailures}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="{DynamicResource Status_Error}" />
                    <Run Text=" " />
                    <Run Text="{Binding Header.FailCount}" Foreground="#FF5555" FontWeight="SemiBold"/>
                </TextBlock>

                <Border Width="1" Height="14" Background="{DynamicResource SystemControlDisabledBaseMediumLowBrush}" Margin="16,0"/>

                <!-- 프리셋명 -->
                <ui:FontIcon Glyph="&#xE713;" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Header.ActivePresetName}" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- 버전 정보 -->
                <TextBlock VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Normal"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Text="{x:Static local:App.Version}"
                           Margin="0,0,4,0" />

                <!-- 언어 선택 (Segmented 제어 방식) -->
                <ListBox ItemsSource="{Binding Header.Languages}"
                         SelectedItem="{Binding Header.SelectedLanguage}"
                         Margin="0,0,-4,0"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalAlignment="Center">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="6,2" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2"
                                                Margin="2,0"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
