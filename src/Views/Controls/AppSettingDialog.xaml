<UserControl x:Class="PixConvert.Views.Controls.AppSettingDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d"
             MinWidth="500"
             Width="500">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ui:SimpleStackPanel Margin="20" Spacing="16">

                <!-- 1. 일반 설정 그룹 -->
                <StackPanel>
                    <TextBlock Text="{DynamicResource Setting_App_General}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="16">
                        <ui:SimpleStackPanel Spacing="12">
                            <!-- 테마 설정 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Setting_App_Theme}" FontWeight="Medium" />
                                    <TextBlock Text="{DynamicResource Setting_App_ThemeDesc}"
                                               FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" SelectedItem="{Binding CurrentTheme}" Width="120" VerticalAlignment="Center">
                                    <ComboBoxItem Content="Light" />
                                    <ComboBoxItem Content="Dark" />
                                    <ComboBoxItem Content="System" />
                                </ComboBox>
                            </Grid>

                            <Separator />
                        </ui:SimpleStackPanel>
                    </Border>
                </StackPanel>

                <!-- 2. 정보 그룹 -->
                <StackPanel>
                    <TextBlock Text="{DynamicResource Setting_App_Info}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="16">
                        <ui:SimpleStackPanel Spacing="12">

                            <!-- 개발자 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Setting_App_Developer}" FontWeight="Medium" />
                                <TextBlock Grid.Column="1" Text="{Binding DeveloperName}" />
                            </Grid>
                        </ui:SimpleStackPanel>
                    </Border>
                </StackPanel>

            </ui:SimpleStackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
