<UserControl x:Class="PixConvert.Views.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:PixConvert.Services"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d">

    <!-- 사이드바 버튼 스타일 정의 -->
    <UserControl.Resources>
        <!-- Sidebar : Button_Style -->
        <Style
            x:Key="SidebarButtonStyle"
            TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
        </Style>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="UserControl">
            <!-- Sidebar : Default_Width -->
            <Setter Property="Width" Value="180" />
            <Style.Triggers>
                <!-- Sidebar : Width_Expansion_Trigger -->
                <DataTrigger
                    Binding="{Binding CurrentStatus}"
                    Value="">
                    <Setter Property="Width" Value="360" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <!-- Sidebar : Main_Layout -->
    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        PanningMode="VerticalOnly"
        VerticalScrollBarVisibility="Hidden">

        <Border
            Margin="0"
            Padding="12"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
            BorderThickness="1"
            CornerRadius="8">

            <ContentControl Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical">
                                        <!-- Sidebar : File_Operations_Group -->
                                        <Button
                                            Command="{Binding FileInput.AddFilesCommand}"
                                            Content="{DynamicResource Btn_AddFile}"
                                            Style="{StaticResource SidebarButtonStyle}" />
                                        <Button
                                            Command="{Binding FileInput.AddFolderCommand}"
                                            Content="{DynamicResource Btn_AddFolder}"
                                            Style="{StaticResource SidebarButtonStyle}" />

                                        <Separator Margin="0,0,0,8" />

                                        <!-- Sidebar : Conversion_Group -->
                                        <Button
                                            Command="{Binding Conversion.OpenConvertSettingCommand}"
                                            Content="{DynamicResource Btn_ConvertSetting}"
                                            Style="{StaticResource SidebarButtonStyle}" />
                                        <Button
                                            Command="{Binding Conversion.ConvertFilesCommand}"
                                            Content="{DynamicResource Btn_Convert}"
                                            Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                            Style="{StaticResource SidebarButtonStyle}" />

                                        <Separator Margin="0,0,0,8" />

                                        <!-- Sidebar : ListManager_Group -->
                                        <Button
                                            Command="{Binding ListManager.EnterListManagerCommand}"
                                            Content="{DynamicResource Btn_ListManager}"
                                            Style="{StaticResource SidebarButtonStyle}" />

                                        <!-- Sidebar : Sorting_Group -->
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock
                                                Margin="0,0,0,4"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                Text="{DynamicResource Sort_Label}" />

                                            <!-- Sidebar : Sort_Selection -->
                                            <ComboBox
                                                Margin="0,0,0,2"
                                                HorizontalAlignment="Stretch"
                                                SelectedValue="{Binding SortFilter.SelectedSortType, Mode=TwoWay}"
                                                SelectedValuePath="Tag">
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Index}"
                                                    Tag="{x:Static services:SortType.AddIndex}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_NameIndex}"
                                                    Tag="{x:Static services:SortType.NameIndex}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_NamePath}"
                                                    Tag="{x:Static services:SortType.NamePath}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_PathIndex}"
                                                    Tag="{x:Static services:SortType.PathIndex}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_PathName}"
                                                    Tag="{x:Static services:SortType.PathName}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Size}"
                                                    Tag="{x:Static services:SortType.Size}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Extension}"
                                                    Tag="{x:Static services:SortType.Extension}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Signature}"
                                                    Tag="{x:Static services:SortType.Signature}" />
                                            </ComboBox>

                                            <!-- Sidebar : Filter_Options -->
                                            <ui:ToggleSwitch
                                                IsOn="{Binding SortFilter.IsSortAscending}"
                                                OffContent="{DynamicResource Sort_Desc}"
                                                OnContent="{DynamicResource Sort_Asc}" />
                                            <ui:ToggleSwitch
                                                Margin="0,0,0,4"
                                                IsOn="{Binding SortFilter.ShowMismatchOnly}"
                                                OffContent="{DynamicResource Option_MismatchOnly}"
                                                OnContent="{DynamicResource Option_MismatchOnly}"
                                                ToolTip="{DynamicResource Tip_MismatchOnly}" />
                                            <Button
                                                Command="{Binding SortFilter.ReorderNumberCommand}"
                                                Content="{DynamicResource Btn_ReorderIndex}"
                                                Style="{StaticResource SidebarButtonStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <!-- Sidebar : Trigger_Converting -->
                            <DataTrigger
                                Binding="{Binding CurrentStatus}"
                                Value="Converting">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                    <StackPanel Orientation="Vertical">
                                                        <!-- Sidebar : Converting_Status -->
                                                        <Button
                                                            Command="{Binding Conversion.CancelConvertCommand}"
                                                            Content="{DynamicResource Btn_Cancel}"
                                                            Foreground="#FF5555"
                                                            Style="{StaticResource SidebarButtonStyle}" />

                                                        <Separator Margin="0,0,0,8" />

                                                        <TextBlock
                                                            Margin="0,0,0,4"
                                                            FontSize="14"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                            Text="{DynamicResource Converting_Title}" />

                                                        <!-- Sidebar : Converting_Details -->
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <ProgressBar Grid.Row="0"
                                                                Height="6"
                                                                Margin="0,4,0,0"
                                                                Maximum="100"
                                                                Minimum="0"
                                                                Value="{Binding Conversion.ConvertProgressPercent}" />

                                                            <TextBlock
                                                                Grid.Row="1"
                                                                TextAlignment="Right">
                                                                <Run
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                                    Text="{Binding Conversion.ProcessedCount}" />
                                                                <Run
                                                                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                                    Text="/" />
                                                                <Run
                                                                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                                    Text="{Binding Conversion.TotalConvertCount}" />
                                                            </TextBlock>

                                                            <TextBlock
                                                                Grid.Row="2"
                                                                TextAlignment="Right"
                                                                Foreground="#FF5555">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger
                                                                                Binding="{Binding Conversion.HasFailures}"
                                                                                Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                                <Run Text="{DynamicResource Converting_FailCount}" />
                                                                <Run Text=":" />
                                                                <Run
                                                                    FontWeight="SemiBold"
                                                                    Text="{Binding Conversion.FailCount}"
                                                                     />
                                                            </TextBlock>
                                                        </Grid>

                                                        <Separator Margin="0,0,0,8"/>

                                                        <!-- Sidebar : Active_Process_List -->
                                                        <ItemsControl ItemsSource="{Binding Conversion.ActiveProcesses}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,0,0,4">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock
                                                                            Grid.Column="0"
                                                                            FontSize="11"
                                                                            Text="{Binding FileName}"
                                                                            TextTrimming="CharacterEllipsis"
                                                                            ToolTip="{Binding FileName}" />
                                                                        <Border
                                                                            Grid.Column="1"
                                                                            Margin="4,0,0,0"
                                                                            Padding="4,1"
                                                                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                                            CornerRadius="2">
                                                                            <TextBlock
                                                                                FontSize="9"
                                                                                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                                                Text="{Binding EngineName}" />
                                                                        </Border>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </ScrollViewer>

                                                <!-- Sidebar : Job Summary (Extended) -->
                                                <StackPanel Grid.Row="1" Orientation="Vertical">
                                                    <Separator Margin="0,8,0,8" />
                                                    <Grid Margin="0,0,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        
                                                        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Text="{DynamicResource Converting_Format}" Margin="0,0,0,2"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" Text="{Binding Conversion.CurrentTargetFormat}" Margin="8,0,0,2"/>

                                                        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Text="{DynamicResource Converting_Cpu}" Margin="0,0,0,2"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" Text="{Binding Conversion.CurrentCpuUsage}" Margin="8,0,0,2"/>

                                                        <TextBlock Grid.Row="2" Grid.Column="0" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Text="{DynamicResource Converting_Quality}" Margin="0,0,0,2"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" Text="{Binding Conversion.CurrentQuality}" Margin="8,0,0,2"/>

                                                        <TextBlock Grid.Row="3" Grid.Column="0" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Text="{DynamicResource Converting_BgColor}" Margin="0,0,0,2"/>
                                                        <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" Text="{Binding Conversion.CurrentBgColor}" Margin="8,0,0,2"/>

                                                        <TextBlock Grid.Row="4" Grid.Column="0" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Text="{DynamicResource Converting_KeepExif}" Margin="0,0,0,2"/>
                                                        <TextBlock Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" Text="{Binding Conversion.CurrentKeepExif}" Margin="8,0,0,2"/>

                                                        <TextBlock Grid.Row="5" Grid.Column="0" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Text="{DynamicResource Converting_Overwrite}" Margin="0,0,0,2"/>
                                                        <TextBlock Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" Text="{Binding Conversion.CurrentOverwritePolicy}" Margin="8,0,0,2"/>

                                                        <TextBlock Grid.Row="6" Grid.Column="0" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Text="{DynamicResource Converting_SaveStrategy}" Margin="0,0,0,2"/>
                                                        <TextBlock Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" Text="{Binding Conversion.CurrentSaveStrategy}" Margin="8,0,0,2"/>

                                                        <TextBlock Grid.Row="7" Grid.Column="0" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Text="{DynamicResource Converting_SaveLocation}" />
                                                        <TextBlock Grid.Row="7" Grid.Column="1" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" Text="{Binding Conversion.CurrentSaveLocation}" ToolTip="{Binding Conversion.CurrentSaveLocationTooltip}" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <!-- Sidebar : Trigger_ListManager -->
                            <DataTrigger
                                Binding="{Binding CurrentStatus}"
                                Value="ListManager">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <StackPanel Orientation="Vertical">
                                                <!-- Sidebar : Back_Button -->
                                                <Button
                                                    Command="{Binding ListManager.ExitListManagerCommand}"
                                                    Content="{DynamicResource Btn_Back}"
                                                    Style="{StaticResource SidebarButtonStyle}" />
                                                <!-- Sidebar : Clear_All -->
                                                <Button
                                                    Command="{Binding ListManager.RemoveAllListCommand}"
                                                    Content="{DynamicResource Btn_ListClear}"
                                                    Foreground="#FF5555"
                                                    Style="{StaticResource SidebarButtonStyle}" />

                                                <Separator Margin="0,0,0,8" />

                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                    Text="{DynamicResource ListManager_Title}" />

                                                <TextBlock
                                                    Margin="0,0,0,8"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                    Text="{DynamicResource ListManager_Desc}"
                                                    TextWrapping="Wrap" />

                                                <!-- Sidebar : Extension_Tags_Group -->
                                                <ItemsControl
                                                    MinHeight="60"
                                                    Margin="0"
                                                    ItemsSource="{Binding ListManager.FormatTags}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <ToggleButton
                                                                Margin="0,0,4,4"
                                                                Padding="8,4"
                                                                FontSize="11"
                                                                Content="{Binding Format}"
                                                                IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Sidebar : List_Cleaning_Options -->
                                                <CheckBox
                                                    Margin="0,0,0,8"
                                                    Content="{DynamicResource ListManager_Unsupported}"
                                                    FontWeight="SemiBold"
                                                    Foreground="#FF5555"
                                                    IsChecked="{Binding ListManager.RemoveUnsupported, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                <Button
                                                    Margin="0,0,0,4"
                                                    Command="{Binding ListManager.ClearSelectedCommand}"
                                                    Content="{DynamicResource Btn_ClearSelected}"
                                                    Style="{StaticResource SidebarButtonStyle}" />

                                            </StackPanel>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Border>
    </ScrollViewer>
</UserControl>
