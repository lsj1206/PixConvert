<UserControl x:Class="PixConvert.Views.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:PixConvert.Services"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d">

    <!-- 사이드바 버튼 스타일 정의 -->
    <UserControl.Resources>
        <!-- Sidebar : Button_Style -->
        <Style
            x:Key="SidebarButtonStyle"
            TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
        </Style>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="UserControl">
            <!-- Sidebar : Default_Width -->
            <Setter Property="Width" Value="180" />
            <Style.Triggers>
                <!-- Sidebar : Width_Expansion_Trigger -->
                <DataTrigger
                    Binding="{Binding CurrentStatus}"
                    Value="">
                    <Setter Property="Width" Value="360" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <!-- Sidebar : Main_Layout -->
    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        PanningMode="VerticalOnly"
        VerticalScrollBarVisibility="Hidden">

        <Border
            Margin="0"
            Padding="12"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
            BorderThickness="1"
            CornerRadius="8">

            <ContentControl Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical">
                                        <!-- Sidebar : File_Operations_Group -->
                                        <StackPanel Orientation="Vertical">
                                            <Button
                                                Command="{Binding FileInput.AddFilesCommand}"
                                                Content="{DynamicResource Btn_AddFile}"
                                                Style="{StaticResource SidebarButtonStyle}" />
                                            <Button
                                                Command="{Binding FileInput.AddFolderCommand}"
                                                Content="{DynamicResource Btn_AddFolder}"
                                                Style="{StaticResource SidebarButtonStyle}" />

                                            <Separator Margin="0,0,0,8" />

                                            <!-- Sidebar : Conversion_Group -->
                                            <Button
                                                Command="{Binding Conversion.OpenConvertSettingCommand}"
                                                Content="{DynamicResource Btn_ConvertSetting}"
                                                Style="{StaticResource SidebarButtonStyle}" />
                                            <Button
                                                Command="{Binding Conversion.ConvertFilesCommand}"
                                                Content="{DynamicResource Btn_Convert}"
                                                Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                Style="{StaticResource SidebarButtonStyle}" />
                                        </StackPanel>

                                        <Separator Margin="0,0,0,8" />

                                        <!-- Sidebar : Sort_Filter_Group -->
                                        <StackPanel Orientation="Vertical">
                                            <Button
                                                Command="{Binding ListManager.EnterListManagerCommand}"
                                                Content="{DynamicResource Btn_ListManager}"
                                                Style="{StaticResource SidebarButtonStyle}" />

                                            <TextBlock
                                                Margin="0,0,0,4"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                Text="{DynamicResource Sort_Label}" />

                                            <!-- Sidebar : Sort_Selection -->
                                            <ComboBox
                                                Margin="0,0,0,2"
                                                HorizontalAlignment="Stretch"
                                                SelectedValue="{Binding SortFilter.SelectedSortType, Mode=TwoWay}"
                                                SelectedValuePath="Tag">
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Index}"
                                                    Tag="{x:Static services:SortType.AddIndex}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_NameIndex}"
                                                    Tag="{x:Static services:SortType.NameIndex}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_NamePath}"
                                                    Tag="{x:Static services:SortType.NamePath}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_PathIndex}"
                                                    Tag="{x:Static services:SortType.PathIndex}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_PathName}"
                                                    Tag="{x:Static services:SortType.PathName}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Size}"
                                                    Tag="{x:Static services:SortType.Size}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Extension}"
                                                    Tag="{x:Static services:SortType.Extension}" />
                                                <ComboBoxItem
                                                    Content="{DynamicResource Sort_Signature}"
                                                    Tag="{x:Static services:SortType.Signature}" />
                                            </ComboBox>

                                            <!-- Sidebar : Filter_Options -->
                                            <ui:ToggleSwitch
                                                IsOn="{Binding SortFilter.IsSortAscending}"
                                                OffContent="{DynamicResource Sort_Desc}"
                                                OnContent="{DynamicResource Sort_Asc}" />
                                            <ui:ToggleSwitch
                                                Margin="0,0,0,4"
                                                IsOn="{Binding SortFilter.ShowMismatchOnly}"
                                                OffContent="{DynamicResource Option_MismatchOnly}"
                                                OnContent="{DynamicResource Option_MismatchOnly}"
                                                ToolTip="{DynamicResource Tip_MismatchOnly}" />
                                            <Button
                                                Command="{Binding SortFilter.ReorderNumberCommand}"
                                                Content="{DynamicResource Btn_ReorderIndex}"
                                                Style="{StaticResource SidebarButtonStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <!-- Sidebar : Trigger_Converting -->
                            <DataTrigger
                                Binding="{Binding CurrentStatus}"
                                Value="Converting">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <StackPanel
                                                Margin="4"
                                                Orientation="Vertical">
                                                <!-- Sidebar : Converting_Status -->
                                                <TextBlock
                                                    Margin="0,0,0,16"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                    Text="{DynamicResource Status_Processing}" />

                                                <TextBlock
                                                    Margin="0,0,0,8"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Conversion.CurrentFileName}"
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTip="{Binding Conversion.CurrentFileName}" />
                                                <ProgressBar
                                                    Height="6"
                                                    Margin="0,0,0,8"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    Value="{Binding Conversion.ConvertProgressPercent}" />

                                                <!-- Sidebar : Converting_Details -->
                                                <Grid Margin="0,0,0,24">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0">
                                                        <Run
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                            Text="{Binding Conversion.ProcessedCount}" />
                                                        <Run
                                                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                            Text="/" />
                                                        <Run
                                                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                            Text="{Binding Conversion.TotalConvertCount}" />
                                                    </TextBlock>

                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Foreground="#FF5555">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger
                                                                        Binding="{Binding Conversion.HasFailures}"
                                                                        Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{DynamicResource Status_Error}" />
                                                        <Run Text=" " />
                                                        <Run
                                                            FontWeight="SemiBold"
                                                            Text="{Binding Conversion.FailCount}" />
                                                    </TextBlock>
                                                </Grid>
                                                <Button
                                                    Command="{Binding Conversion.CancelConvertCommand}"
                                                    Content="{DynamicResource Btn_Cancel}"
                                                    Foreground="#FF5555"
                                                    Style="{StaticResource SidebarButtonStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <!-- Sidebar : Trigger_ListManager -->
                            <DataTrigger
                                Binding="{Binding CurrentStatus}"
                                Value="ListManager">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <StackPanel Orientation="Vertical">
                                                <!-- Sidebar : Back_Button -->
                                                <Button
                                                    Margin="0,0,0,12"
                                                    Command="{Binding ListManager.ExitListManagerCommand}"
                                                    Content="{DynamicResource Btn_Back}"
                                                    Style="{StaticResource SidebarButtonStyle}" />

                                                <TextBlock
                                                    Margin="0,0,0,12"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                    Text="{DynamicResource ListManager_Title}" />

                                                <TextBlock
                                                    Margin="0,0,0,8"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                    Text="{DynamicResource ListManager_Desc}"
                                                    TextWrapping="Wrap" />

                                                <!-- Sidebar : Extension_Tags_Group -->
                                                <ItemsControl
                                                    Margin="0,0,0,8"
                                                    ItemsSource="{Binding ListManager.ExtensionTags}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <ToggleButton
                                                                Margin="0,0,4,4"
                                                                Padding="8,3"
                                                                FontSize="11"
                                                                Content="{Binding Format}"
                                                                IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Separator Margin="0,4,0,8" />

                                                <!-- Sidebar : List_Cleaning_Options -->
                                                <CheckBox
                                                    Margin="0,0,0,8"
                                                    Content="{DynamicResource ListManager_Unsupported}"
                                                    FontWeight="SemiBold"
                                                    Foreground="#FF5555"
                                                    IsChecked="{Binding ListManager.RemoveUnsupported, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                <Button
                                                    Margin="0,0,0,4"
                                                    Command="{Binding ListManager.RemoveSelectedCommand}"
                                                    Content="{DynamicResource Btn_RemoveSelected}"
                                                    Style="{StaticResource SidebarButtonStyle}" />

                                                <Separator Margin="0,4,0,8" />

                                                <!-- Sidebar : Clear_All -->
                                                <Button
                                                    Margin="0,0,0,8"
                                                    Command="{Binding ListManager.RemoveAllListCommand}"
                                                    Content="{DynamicResource Btn_ListClear}"
                                                    Foreground="#FF5555"
                                                    Style="{StaticResource SidebarButtonStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Border>
    </ScrollViewer>
</UserControl>
