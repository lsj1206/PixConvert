<UserControl
    x:Class="PixConvert.Views.Controls.ConvertSettingDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="clr-namespace:PixConvert.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    Width="600"
    MinWidth="600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style
            x:Key="FormatTagStyle"
            BasedOn="{StaticResource {x:Type ToggleButton}}"
            TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="ui:ControlHelper.CornerRadius" Value="4" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer
            MaxHeight="600"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                Margin="25,14,25,14"
                Orientation="Vertical">

                <!-- ConvertSetting : Preset_Group -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2.6*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- ConvertSetting : Preset_List -->
                    <ComboBox
                        Margin="0,0,8,0"
                        HorizontalAlignment="Stretch"
                        ui:ControlHelper.Header="{DynamicResource Setting_PresetList}"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding Presets}"
                        SelectedItem="{Binding SelectedPreset}" />

                    <!-- ConvertSetting : Preset_NameEdit -->
                    <ctrls:FilterTextBox
                        Grid.Column="1"
                        Margin="0,0,8,0"
                        ui:ControlHelper.Header="{DynamicResource Setting_PresetName}"
                        Filter="None"
                        Text="{Binding PresetNameEdit, UpdateSourceTrigger=PropertyChanged}" />

                    <!-- ConvertSetting : Preset_Apply -->
                    <Button
                        Grid.Column="2"
                        VerticalAlignment="Bottom"
                        Command="{Binding RenamePresetCommand}"
                        Content="{DynamicResource Btn_PresetApply}" />
                </Grid>

                <WrapPanel Margin="0,0,0,16">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding CreatePresetCommand}"
                        Content="{DynamicResource Btn_PresetCreate}" />
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding CopyPresetCommand}"
                        Content="{DynamicResource Btn_PresetCopy}" />
                    <Button
                        Command="{Binding RemovePresetCommand}"
                        Content="{DynamicResource Btn_PresetDelete}"
                        Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                </WrapPanel>

                <Separator Margin="0,0,0,16" />

                <!-- ConvertSetting : Standard_Group -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontWeight="SemiBold"
                    Text="{DynamicResource Setting_GroupStandard}" />
                <ItemsControl
                    Margin="0,0,0,16"
                    ItemsSource="{Binding StandardTargetTags}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton
                                Style="{DynamicResource FormatTagStyle}"
                                Content="{Binding Format, Converter={StaticResource UpperCaseConverter}}"
                                IsChecked="{Binding IsSelected}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ConvertSetting : Animation_Group -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontWeight="SemiBold"
                    Text="{DynamicResource Setting_GroupAnimation}" />
                <ItemsControl
                    Margin="0,0,0,16"
                    ItemsSource="{Binding AnimationTargetTags}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton
                                Style="{DynamicResource FormatTagStyle}"
                                Content="{Binding Format, Converter={StaticResource UpperCaseConverter}}"
                                IsChecked="{Binding IsSelected}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,0,0,16" />

                <!-- ConvertSetting : Quality_Group -->
                <StackPanel
                    Margin="0,0,0,16"
                    HorizontalAlignment="Left"
                    IsEnabled="{Binding IsLossyFormat}">
                    <TextBlock
                        Margin="0,0,0,4"
                        Text="{DynamicResource Setting_Quality}" />
                    <Grid Width="420">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider
                            Margin="0,0,12,0"
                            Maximum="100"
                            Minimum="1"
                            Value="{Binding Quality}" />
                        <TextBlock
                            Grid.Column="1"
                            Width="30"
                            VerticalAlignment="Center"
                            Text="{Binding Quality}"
                            TextAlignment="Right" />
                    </Grid>
                </StackPanel>

                <!-- ConvertSetting : Color_Group (BackgroundColor) -->
                <StackPanel
                    Margin="0,0,0,12"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Text="{DynamicResource Setting_BackgroundColor}" />
                    <ComboBox
                        Width="180"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        SelectedItem="{Binding BgColorOption}">
                        <ComboBoxItem
                            Content="{DynamicResource Bg_White}"
                            IsSelected="{Binding BgColorOption, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=White}"
                            Tag="White" />
                        <ComboBoxItem
                            Content="{DynamicResource Bg_Black}"
                            IsSelected="{Binding BgColorOption, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Black}"
                            Tag="Black" />
                        <ComboBoxItem
                            Content="{DynamicResource Bg_Custom}"
                            IsSelected="{Binding BgColorOption, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Custom}"
                            Tag="Custom" />
                    </ComboBox>

                    <ctrls:FilterTextBox
                        Width="120"
                        VerticalAlignment="Center"
                        Filter="HexColor"
                        IsEnabled="{Binding BgColorOption, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Custom}"
                        Text="{Binding CustomBackgroundColor, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <CheckBox
                    Margin="0,0,0,16"
                    Content="{DynamicResource Setting_KeepExif}"
                    IsChecked="{Binding KeepExif}" />

                <!-- ConvertSetting : Overwrite_Group -->
                <TextBlock
                    Margin="0,0,0,4"
                    Text="{DynamicResource Setting_OverwritePolicy}" />
                <WrapPanel Margin="0,0,0,16">
                    <RadioButton
                        Margin="0,0,16,0"
                        Content="{DynamicResource Setting_Overwrite_Suffix}"
                        GroupName="OverwriteGroup"
                        IsChecked="{Binding OverwriteSide, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Suffix}" />
                    <RadioButton
                        Margin="0,0,16,0"
                        Content="{DynamicResource Setting_Overwrite_Skip}"
                        GroupName="OverwriteGroup"
                        IsChecked="{Binding OverwriteSide, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Skip}" />
                    <RadioButton
                        Content="{DynamicResource Setting_Overwrite_Overwrite}"
                        GroupName="OverwriteGroup"
                        IsChecked="{Binding OverwriteSide, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Overwrite}" />
                </WrapPanel>

                <!-- ConvertSetting : OutputLocation_Group -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontWeight="SemiBold"
                    Text="{DynamicResource Setting_OutputLocation}" />
                <StackPanel Margin="0,0,0,16">
                    <RadioButton
                        Margin="0,0,0,8"
                        Content="{DynamicResource Setting_OutputLocation_Same}"
                        GroupName="OutputLocationGroup"
                        IsChecked="{Binding OutputLocation, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=SameAsOriginal}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <RadioButton
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Setting_OutputLocation_Custom}"
                            GroupName="OutputLocationGroup"
                            IsChecked="{Binding OutputLocation, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Custom}" />
                        <TextBox
                            Grid.Column="1"
                            Margin="0,0,8,0"
                            MinWidth="220"
                            VerticalAlignment="Center"
                            IsEnabled="{Binding OutputLocation, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Custom}"
                            IsReadOnly="True"
                            Text="{Binding CustomOutputPath, Mode=TwoWay}" />
                        <Button
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Command="{Binding ChangeOutputPathCommand}"
                            Content="{DynamicResource Btn_Browse}"
                            IsEnabled="{Binding OutputLocation, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Custom}" />
                    </Grid>
                </StackPanel>

                <!-- ConvertSetting : Strategy_Group -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontWeight="SemiBold"
                    Text="{DynamicResource Setting_OutputStrategy}" />
                <StackPanel Margin="0,0,0,16">
                    <RadioButton
                        Margin="0,0,0,8"
                        Content="{DynamicResource Setting_OutputStrategy_NoFolder}"
                        GroupName="OutputStrategyGroup"
                        IsChecked="{Binding FolderStrategy, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=NoFolder}" />
                    <StackPanel Orientation="Horizontal">
                        <RadioButton
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Setting_OutputStrategy_CreateFolder}"
                            GroupName="OutputStrategyGroup"
                            IsChecked="{Binding FolderStrategy, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=CreateFolder}" />

                        <ctrls:FilterTextBox
                            MinWidth="160"
                            Filter="InvalidSpecial"
                            FilterMode="Block"
                            IsEnabled="{Binding FolderStrategy, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=CreateFolder}"
                            Text="{Binding OutputSubFolderName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>

                <!-- ConvertSetting : Cpu_Group -->
                <TextBlock
                    Margin="0,0,0,4"
                    Text="{DynamicResource Setting_CpuUsage}" />
                <ComboBox
                    Width="240"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Left"
                    SelectedItem="{Binding CpuUsage}">
                    <ComboBoxItem
                        Content="{DynamicResource Setting_Cpu_Max}"
                        IsSelected="{Binding CpuUsage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Max}"
                        Tag="Max" />
                    <ComboBoxItem
                        Content="{DynamicResource Setting_Cpu_Optimal}"
                        IsSelected="{Binding CpuUsage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Optimal}"
                        Tag="Optimal" />
                    <ComboBoxItem
                        Content="{DynamicResource Setting_Cpu_Half}"
                        IsSelected="{Binding CpuUsage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Half}"
                        Tag="Half" />
                    <ComboBoxItem
                        Content="{DynamicResource Setting_Cpu_Low}"
                        IsSelected="{Binding CpuUsage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Low}"
                        Tag="Low" />
                    <ComboBoxItem
                        Content="{DynamicResource Setting_Cpu_Minimum}"
                        IsSelected="{Binding CpuUsage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Minimum}"
                        Tag="Minimum" />
                </ComboBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
