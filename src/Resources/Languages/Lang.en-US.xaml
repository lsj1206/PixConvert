<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- App/Window Common -->
    <sys:String x:Key="App_Title">PixConvert</sys:String>

    <!-- Header : Dashboard -->
    <sys:String x:Key="Status_Total">Total</sys:String>
    <sys:String x:Key="Status_Unknown">Unsupported</sys:String>

    <!-- List : Item -->
    <sys:String x:Key="List_Index">Index</sys:String>
    <sys:String x:Key="List_Name">Name</sys:String>
    <sys:String x:Key="List_Extension">Ext.</sys:String>
    <sys:String x:Key="List_Signature">Format</sys:String>
    <sys:String x:Key="List_Status">Status</sys:String>
    <sys:String x:Key="List_Size">Size</sys:String>
    <sys:String x:Key="List_Path">Path</sys:String>

    <!-- List : Status -->
    <sys:String x:Key="Status_Pending">Ready</sys:String>
    <sys:String x:Key="Status_Processing">Converting</sys:String>
    <sys:String x:Key="Status_Success">Success</sys:String>
    <sys:String x:Key="Status_Error">Error</sys:String>
    <sys:String x:Key="Status_Unsupported">N/A</sys:String>
    <sys:String x:Key="Status_Skipped">Skipped</sys:String>

    <!-- Sidebar : Button -->
    <sys:String x:Key="Btn_AddFile">Add File</sys:String>
    <sys:String x:Key="Btn_AddFolder">Add Folder</sys:String>
    <sys:String x:Key="Btn_ConvertSetting">Convert Setting</sys:String>
    <sys:String x:Key="Btn_Convert">Convert</sys:String>
    <sys:String x:Key="Btn_Cancel">Cancel</sys:String>
    <sys:String x:Key="Btn_ListManager">List Manager</sys:String>
    <sys:String x:Key="Btn_ReorderIndex">Reorder Index</sys:String>

    <!-- Sidebar : Option -->
    <sys:String x:Key="Sort_Label">Sort</sys:String>
    <sys:String x:Key="Sort_Asc">Ascending</sys:String>
    <sys:String x:Key="Sort_Desc">Descending</sys:String>
    <sys:String x:Key="Option_MismatchOnly">Diff Filter</sys:String>
    <sys:String x:Key="Tip_MismatchOnly">Filter only files where extension and format signature differ.</sys:String>

    <!-- Sidebar : Sorting -->
    <sys:String x:Key="Sort_Index">Index</sys:String>
    <sys:String x:Key="Sort_NameIndex">Name-Index</sys:String>
    <sys:String x:Key="Sort_NamePath">Name-Path</sys:String>
    <sys:String x:Key="Sort_PathIndex">Path-Index</sys:String>
    <sys:String x:Key="Sort_PathName">Path-Name</sys:String>
    <sys:String x:Key="Sort_Size">Size</sys:String>
    <sys:String x:Key="Sort_Extension">Ext.</sys:String>
    <sys:String x:Key="Sort_Signature">Format</sys:String>

    <!-- Sidebar : List Manager -->
    <sys:String x:Key="Btn_Back">Exit</sys:String>
    <sys:String x:Key="Btn_ListClear">Clear All Items</sys:String>
    <sys:String x:Key="ListManager_Title">List Manager</sys:String>
    <sys:String x:Key="ListManager_Desc">Select Format to remove.</sys:String>
    <sys:String x:Key="ListManager_Unsupported">Unsupported</sys:String>
    <sys:String x:Key="Btn_ClearSelected">Clear Selected</sys:String>

    <!-- Sidebar : Converting -->
    <sys:String x:Key="Converting_Title">Converting</sys:String>
    <sys:String x:Key="Converting_FailCount">Failed</sys:String>

    <sys:String x:Key="Converting_Cpu">CPU Usage</sys:String>
    <sys:String x:Key="Converting_Format">Target Format</sys:String>
    <sys:String x:Key="Converting_Quality">Quality</sys:String>
    <sys:String x:Key="Converting_BgColor">Background</sys:String>
    <sys:String x:Key="Converting_KeepExif">Keep EXIF</sys:String>
    <sys:String x:Key="Converting_Duplicates">Duplicates</sys:String>
    <sys:String x:Key="Converting_SaveMethod">Save Method</sys:String>
    <sys:String x:Key="Converting_SaveLocation">Save to...</sys:String>

    <!-- Convert Setting : Preset -->
    <sys:String x:Key="Setting_PresetList">Select Preset</sys:String>
    <sys:String x:Key="Setting_PresetName">Rename</sys:String>
    <sys:String x:Key="Btn_PresetApply">Apply</sys:String>
    <sys:String x:Key="Btn_PresetCreate">Create Preset</sys:String>
    <sys:String x:Key="Btn_PresetCopy">Copy Preset</sys:String>
    <sys:String x:Key="Btn_PresetDelete">Delete Preset</sys:String>

    <!-- Convert Setting -->
    <sys:String x:Key="Setting_GroupStandard">Standard Image Format</sys:String>
    <sys:String x:Key="Setting_GroupAnimation">Animation Image Format</sys:String>
    <sys:String x:Key="Setting_Quality">Quality</sys:String>
    <sys:String x:Key="Setting_BackgroundColor">Background Color(Transparency)</sys:String>
    <sys:String x:Key="Setting_KeepExif">Keep Metadata(EXIF)</sys:String>

    <!-- Convert Setting : BgColor -->
    <sys:String x:Key="Bg_White">White</sys:String>
    <sys:String x:Key="Bg_Black">Black</sys:String>
    <sys:String x:Key="Bg_Custom">Custom(HEX)</sys:String>

    <!-- Convert Setting : Duplicate File Policy -->
    <sys:String x:Key="Setting_OverwritePolicy">Duplicate File Policy</sys:String>
    <sys:String x:Key="Setting_Overwrite_Suffix">Add Suffix</sys:String>
    <sys:String x:Key="Setting_Overwrite_Skip">Skip</sys:String>
    <sys:String x:Key="Setting_Overwrite_Overwrite">Overwrite</sys:String>
    <!-- Convert Setting : Save Location -->
    <sys:String x:Key="Setting_SaveLocation">Save Location</sys:String>
    <sys:String x:Key="Setting_SaveLocation_Same">Same as Original</sys:String>
    <sys:String x:Key="Setting_SaveLocation_Custom">Custom Path</sys:String>
    <sys:String x:Key="Btn_Browse">Browse...</sys:String>
    <!-- Convert Setting : Save Method -->
    <sys:String x:Key="Setting_SaveMethod">Save Method</sys:String>
    <sys:String x:Key="Setting_SaveMethod_NoFolder">File Only</sys:String>
    <sys:String x:Key="Setting_SaveMethod_CreateFolder">Create Folder</sys:String>

    <!-- Convert Setting : CPU Usage -->
    <sys:String x:Key="Setting_CpuUsage">CPU Usage</sys:String>
    <sys:String x:Key="Setting_Cpu_Max">Max: 90%</sys:String>
    <sys:String x:Key="Setting_Cpu_Optimal">Optimal: 75%</sys:String>
    <sys:String x:Key="Setting_Cpu_Half">Half: 50%</sys:String>
    <sys:String x:Key="Setting_Cpu_Low">Low: 25%</sys:String>
    <sys:String x:Key="Setting_Cpu_Minimum">Minimum: Single Core</sys:String>

    <!-- Snackbar -->
    <sys:String x:Key="Msg_AddFile">{0:N0} file(s) added</sys:String>
    <sys:String x:Key="Msg_AddWithLimit">{0:N0} file(s) added, {1:N0} excluded</sys:String>
    <sys:String x:Key="Msg_AddWithDuplicate">{0:N0} file(s) added, {1:N0} duplicates skipped</sys:String>
    <sys:String x:Key="Msg_AlreadyExists">Already exists in the list.</sys:String>
    <sys:String x:Key="Msg_FileAddError">Error adding file: {0}</sys:String>
    <sys:String x:Key="Msg_LimitReached">Cannot add more files.</sys:String>
    <sys:String x:Key="Msg_NoNewFiles">No files available to add.</sys:String>
    <sys:String x:Key="Msg_ReorderIndex">Reordering index.</sys:String>
    <sys:String x:Key="Msg_RemoveFile">Removing {0} file(s) from list.</sys:String>
    <sys:String x:Key="Msg_ClearList">Clearing list.</sys:String>
    <sys:String x:Key="Msg_Error_Occurred">Error: {0}</sys:String>
    <sys:String x:Key="Msg_LoadingFile">Loading files...</sys:String>
    <sys:String x:Key="Msg_LoadingFileProgress">Loading files... ({0}/{1})</sys:String>
    <sys:String x:Key="Err_PathTooLong">Fail: Name or Path is too long.</sys:String>
    <sys:String x:Key="Err_FileNotFound">Fail: Original not found.</sys:String>
    <sys:String x:Key="Err_Unauthorized">Fail: Access denied.</sys:String>
    <sys:String x:Key="Err_IO">Fail: Invalid name.</sys:String>
    <sys:String x:Key="Msg_OperationComplete">{0} operation(s) complete.</sys:String>
    <sys:String x:Key="Msg_OperationCompleteWithSkipped">{0} converted, {1} skipped</sys:String>
    <sys:String x:Key="Msg_Convert_Cancelling">Cancelling operation...</sys:String>
    <sys:String x:Key="Msg_Convert_Cancelled">Operation has been cancelled.</sys:String>
    <sys:String x:Key="Msg_Error_ConfigInvalid">Invalid conversion settings. Please reconfigure.</sys:String>
    <sys:String x:Key="Msg_Preset_SaveSuccess">Settings saved successfully</sys:String>
    <sys:String x:Key="Msg_Preset_SaveError">Failed to save settings</sys:String>

    <!-- Dialog -->
    <sys:String x:Key="Err_Fatal_Title">Startup Error</sys:String>
    <sys:String x:Key="Err_Fatal_Init">An error occurred while starting the application:\n{0}</sys:String>
    <sys:String x:Key="Dlg_Yes">Yes</sys:String>
    <sys:String x:Key="Dlg_No">No</sys:String>
    <sys:String x:Key="Dlg_Confirm">Confirm</sys:String>
    <sys:String x:Key="Dlg_Cancel">Cancel</sys:String>

    <!-- Convert -->
    <sys:String x:Key="Dlg_Title_Convert">Conversion</sys:String>
    <sys:String x:Key="Dlg_Ask_Convert">Are you sure you want to convert {0} file(s)?</sys:String>

    <!-- Cancel Convert -->
    <sys:String x:Key="Dlg_Title_CancelConvert">Cancel Conversion</sys:String>
    <sys:String x:Key="Dlg_Ask_CancelConvert">Are you sure you want to cancel?</sys:String>
    <sys:String x:Key="Dlg_Warn_CancelConvert">⚠️ Tasks already in progress will not be cancelled.</sys:String>

    <!-- Reorder Index -->
    <sys:String x:Key="Dlg_Title_ReorderIndex">Reorder Index</sys:String>
    <sys:String x:Key="Dlg_Ask_ReorderIndex">Reindex based on current order?</sys:String>
    <sys:String x:Key="Dlg_Warn_ReorderIndex">⚠️ Existing indexes will be reset.</sys:String>

    <!-- Clear List -->
    <sys:String x:Key="Dlg_Title_ClearList">Clear List</sys:String>
    <sys:String x:Key="Dlg_Ask_ClearList">Clear all files from the list?</sys:String>

    <!-- Delete File -->
    <sys:String x:Key="Dlg_Title_DeleteConfirm">Remove</sys:String>
    <sys:String x:Key="Dlg_Ask_DeleteSingle">Remove the selected file from the list?</sys:String>
    <sys:String x:Key="Dlg_Ask_DeleteMulti">Remove {0} files from the list?</sys:String>

    <!-- Add Folder -->
    <sys:String x:Key="Dlg_Title_AddFile">Add File</sys:String>
    <sys:String x:Key="Dlg_Title_AddFolder">Add Folder</sys:String>
    <sys:String x:Key="Dlg_Title_SelectOutputPath">Select Output Folder</sys:String>

    <!-- App Setting -->
    <sys:String x:Key="Dlg_Title_AppSetting">Settings</sys:String>
    <sys:String x:Key="Setting_App_General">General</sys:String>
    <sys:String x:Key="Setting_App_Language">Language</sys:String>
    <sys:String x:Key="Setting_App_LanguageDesc">Select the display language.</sys:String>
    <sys:String x:Key="Setting_App_DelConfirm">Delete Confirm</sys:String>
    <sys:String x:Key="Setting_App_DelConfirmDesc">Turn ON/OFF file delete confirm dialog.</sys:String>
    <sys:String x:Key="Setting_App_Info">App Info</sys:String>
    <sys:String x:Key="Setting_App_Version">Version</sys:String>

</ResourceDictionary>
