    <!-- Convert Setting : Option Tips -->
    <sys:String x:Key="Tip_Avif">⚠️AVIF conversion tasks consume a lot of CPU resources.</sys:String>
    <sys:String x:Key="SettingTip_CpuUsage_Title">Sets the number of concurrent conversion jobs.</sys:String>
    <sys:String x:Key="SettingTip_CpuUsage_Body">The job count is determined by the number of CPU cores and threads.</sys:String>
    <sys:String x:Key="SettingTip_OverwritePolicy_Title">Selects what to do when a file with the same name already exists in the output path.</sys:String>
    <sys:String x:Key="SettingTip_StandardLossless_Title">Sets lossless or lossy compression.</sys:String>
    <sys:String x:Key="SettingTip_StandardQuality_Title">Sets the quality for lossy compression.</sys:String>
    <sys:String x:Key="SettingTip_JpegChromaSubsampling_Title">Sets chroma resolution.</sys:String>
    <sys:String x:Key="SettingTip_JpegChromaSubsampling_Body" xml:space="preserve">• 4:4:4 keeps luma and chroma at the same resolution.
• 4:2:2 reduces chroma resolution horizontally.
• 4:2:0 reduces chroma resolution horizontally and vertically.</sys:String>
    <sys:String x:Key="SettingTip_JpegChromaSubsampling_Caution">⚠️ For AVIF-to-JPEG conversion, 4:2:2 is applied as either 4:4:4 or 4:2:0 depending on quality.</sys:String>
    <sys:String x:Key="SettingTip_PngCompression_Title">Sets compression strength.</sys:String>
    <sys:String x:Key="SettingTip_PngCompression_Body" xml:space="preserve">Image quality is not changed.
• 0: No compression, fast, large file
• 6: Default
• 9: Maximum compression, slow, small file</sys:String>
    <sys:String x:Key="SettingTip_AvifChromaSubsampling_Title">For lossy saves, sets chroma resolution.</sys:String>
    <sys:String x:Key="SettingTip_AvifChromaSubsampling_Body" xml:space="preserve">• Auto: Applies 4:4:4 when quality is 90 or higher, otherwise 4:2:0.
• On (4:2:0): Reduces chroma resolution horizontally and vertically.
• Off (4:4:4): Keeps luma and chroma at the same resolution.</sys:String>
    <sys:String x:Key="SettingTip_AvifEncodingEffort_Title">Determines how much CPU time is spent searching for better compression results.</sys:String>
    <sys:String x:Key="SettingTip_AvifEncodingEffort_Body" xml:space="preserve">• 0: Fast encoding, larger file
• 4: Default
• 9: Slow encoding, smaller file</sys:String>
    <sys:String x:Key="SettingTip_AvifEncodingEffort_Caution">⚠️Higher values result in longer encoding times.</sys:String>
    <sys:String x:Key="SettingTip_AvifBitDepth_Title">Sets color precision per channel.</sys:String>
    <sys:String x:Key="SettingTip_AvifBitDepth_Body" xml:space="preserve">• Auto: Determined automatically from the input image type.
• 8-bit: 256 levels, common
• 10-bit: 1024 levels
• 12-bit: 4096 levels</sys:String>
    <sys:String x:Key="SettingTip_BackgroundColor_Title">Used when saving to formats that do not support alpha transparency.</sys:String>
    <sys:String x:Key="SettingTip_AnimationLossless_Title">Sets lossless or lossy compression.</sys:String>
    <sys:String x:Key="SettingTip_AnimationQuality_Title">Sets the quality for lossy compression.</sys:String>
    <sys:String x:Key="SettingTip_WebpPreset_Title">Adjusts lossy compression using an image-type hint.</sys:String>
    <sys:String x:Key="SettingTip_PreserveTransparentPixels_Title">Sets whether RGB values in transparent pixels are preserved during lossless compression.</sys:String>
    <sys:String x:Key="SettingTip_WebpEncodingEffort_Title">Determines how much CPU time is spent searching for better compression results.</sys:String>
    <sys:String x:Key="SettingTip_WebpEncodingEffort_Body" xml:space="preserve">• 0: Fast encoding, larger file
• 4: Default
• 6: Slow encoding, smaller file</sys:String>
    <sys:String x:Key="SettingTip_GifPalettePreset_Title">Sets bit depth and dithering.</sys:String>
    <sys:String x:Key="SettingTip_GifPalettePreset_Body" xml:space="preserve">Bit depth: Upper limit for colors per frame
Dithering: Distributes color error from the source across neighboring pixels
• Minimal: 6-bit (64 colors), no dithering
• Simple: 7-bit (128 colors), dithering 0.3
• Standard: 8-bit (256 colors), no dithering
• Balance: 8-bit (256 colors), dithering 0.3
• Vivid: 8-bit (256 colors), dithering 0.5</sys:String>
    <sys:String x:Key="SettingTip_InterframeMaxError_Title">Sets the tolerance when optimizing similar areas between frames as transparent.</sys:String>
    <sys:String x:Key="SettingTip_InterframeMaxError_Caution">Higher values can introduce ghosting or edge errors.</sys:String>
    <sys:String x:Key="SettingTip_InterpaletteMaxError_Title">Sets the tolerance when optimizing by reusing similar colors between frames.</sys:String>
    <sys:String x:Key="SettingTip_InterpaletteMaxError_Caution">Higher values can reduce color accuracy.</sys:String>
