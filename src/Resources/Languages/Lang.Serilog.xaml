<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- App.xaml.cs -->
    <system:String x:Key="Log_App_Start">=== PixConvert started ===</system:String>
    <system:String x:Key="Log_App_End">=== PixConvert closed ===</system:String>
    <system:String x:Key="Log_UI_UnhandledException">[UI Thread] Unhandled exception.</system:String>
    <system:String x:Key="Log_Background_UnhandledException">[Background Task] Unhandled exception.</system:String>
    <system:String x:Key="Log_AppDomain_UnhandledException">[AppDomain] Fatal runtime exception.</system:String>
    <system:String x:Key="Log_App_FatalInit">[App] Fatal startup error.</system:String>

    <!-- FileInputViewModel.cs -->
    <system:String x:Key="Log_Sidebar_ProcessStart">[FileInputViewModel] Add files started. Count={Count}</system:String>
    <system:String x:Key="Log_Sidebar_ProcessError">[FileInputViewModel] Add files failed.</system:String>

    <!-- FileScannerService.cs -->
    <system:String x:Key="Log_File_SignatureFail">[FileScannerService] Signature read failed. Path={Path}</system:String>
    <system:String x:Key="Log_File_MetaFail">[FileScannerService] Metadata read failed. Path={Path}</system:String>
    <system:String x:Key="Log_File_FolderAccessFail">[FileScannerService] Folder access denied. Skipped. Path={DirPath}</system:String>
    <system:String x:Key="Log_File_FolderTraverseFail">[FileScannerService] Folder traversal failed. Path={DirPath}</system:String>

    <!-- DriveInfoService.cs / FileAnalyzerService.cs -->
    <system:String x:Key="Log_Process_WmiDiskNumber">[DriveInfoService] WMI disk mapping started. Drive={DriveLetter}</system:String>
    <system:String x:Key="Log_Process_WmiSsdCheck">[DriveInfoService] WMI disk type checked. Disk={DiskNumber}, IsSsd={IsSsd}</system:String>
    <system:String x:Key="Log_Process_WmiFail">[DriveInfoService] WMI disk mapping failed. Drive={DriveLetter}</system:String>
    <system:String x:Key="Log_Process_WmiException">[DriveInfoService] WMI disk check failed. Path={RootPath}</system:String>
    <system:String x:Key="Log_Process_WmiUnknown">[DriveInfoService] WMI disk type unknown. Disk={DiskNumber}</system:String>
    <system:String x:Key="Log_Process_Parallelism">[DriveInfoService] Parallelism selected. DriveType={DriveType}, Parallelism={Parallelism}</system:String>
    <system:String x:Key="Log_Process_Summary">[FileAnalyzerService] File analysis completed. InputPaths={InputPaths}, Added={Added}, Duplicate={Dup}, Ignored={Ignored}, Failed={Failed}, ElapsedMs={Time}</system:String>
    <system:String x:Key="Log_Process_LimitReached">[FileAnalyzerService] File limit reached. Limit={Limit}, Ignored={Count}</system:String>

    <!-- PresetService.cs -->
    <system:String x:Key="Log_Preset_FileNotFound">[PresetService] Preset file not found. Using defaults.</system:String>
    <system:String x:Key="Log_Preset_FileEmpty">[PresetService] Preset file is empty. Using defaults.</system:String>
    <system:String x:Key="Log_Preset_FileLoadSuccess">[PresetService] Preset file loaded.</system:String>
    <system:String x:Key="Log_Preset_FileLoadError">[PresetService] Preset file load failed. Using defaults.</system:String>
    <system:String x:Key="Log_Preset_FileSaveSuccess">[PresetService] Preset file saved.</system:String>
    <system:String x:Key="Log_Preset_FileSaveError">[PresetService] Preset file save failed.</system:String>
    <system:String x:Key="Log_Preset_NotFoundSelected">[PresetService] Selected preset not found. Name={LastSelectedPresetName}</system:String>
    <system:String x:Key="Log_Preset_ValidDataStart">[PresetService] Preset validation started.</system:String>
    <system:String x:Key="Log_Preset_SettingsNull">[PresetService] Preset settings are null.</system:String>
    <system:String x:Key="Log_Preset_InvalidQuality">[PresetService] Invalid numeric option. Value={Quality}</system:String>
    <system:String x:Key="Log_Preset_InvalidStdFormat">[PresetService] Invalid standard target format. Format={Format}</system:String>
    <system:String x:Key="Log_Preset_InvalidAnimFormat">[PresetService] Invalid animation target format. Format={Format}</system:String>
    <system:String x:Key="Log_Preset_InvalidEnum">[PresetService] Invalid enum option.</system:String>
    <system:String x:Key="Log_Preset_InvalidBgColor">[PresetService] Invalid background color. Color={Color}</system:String>
    <system:String x:Key="Log_Preset_DataValid">[PresetService] Preset validation completed.</system:String>
    <system:String x:Key="Log_Preset_EmptyCustomPath">[PresetService] Custom output path is empty.</system:String>
    <system:String x:Key="Log_Preset_SubFolderEmpty">[PresetService] Output subfolder name is empty.</system:String>
    <system:String x:Key="Log_Preset_SubFolderInvalid">[PresetService] Output subfolder name is invalid. Name={Name}</system:String>

    <!-- SettingService.cs -->
    <system:String x:Key="Log_Setting_FileNotFound">[SettingService] Settings file not found. Using defaults.</system:String>
    <system:String x:Key="Log_Setting_FileEmpty">[SettingService] Settings file is empty. Using defaults.</system:String>
    <system:String x:Key="Log_Setting_FileLoadSuccess">[SettingService] Settings file loaded.</system:String>
    <system:String x:Key="Log_Setting_FileLoadError">[SettingService] Settings file load failed. Using defaults.</system:String>
    <system:String x:Key="Log_Setting_FileSaveSuccess">[SettingService] Settings file saved.</system:String>
    <system:String x:Key="Log_Setting_FileSaveError">[SettingService] Settings file save failed.</system:String>
    <system:String x:Key="Log_Setting_FileBackupCreated">[SettingService] Corrupted settings file backed up. Path={BackupPath}</system:String>
    <system:String x:Key="Log_Setting_FileBackupFailed">[SettingService] Failed to back up corrupted settings file. Path={Path}</system:String>

    <!-- SnackbarService.cs -->
    <system:String x:Key="Log_Snackbar_ShowError">[SnackbarService] Show failed.</system:String>
    <system:String x:Key="Log_Snackbar_ShowProgressError">[SnackbarService] ShowProgress failed.</system:String>

    <!-- ConversionViewModel.cs / Providers -->
    <system:String x:Key="Log_Conversion_FileError">[ConversionViewModel] File conversion failed. Path={Path}</system:String>
    <system:String x:Key="Log_Conversion_BatchStart">[ConversionViewModel] Batch conversion started. Count={Count}</system:String>
    <system:String x:Key="Log_Conversion_PathCollision">[ConversionViewModel] Output path collision. Path={Path}</system:String>
    <system:String x:Key="Log_Skia_EncodeFail">[SkiaSharpProvider] Failed to encode {0}.</system:String>

</ResourceDictionary>
