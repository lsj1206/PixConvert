<Application
    x:Class="PixConvert.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:PixConvert.Converters"
    xmlns:local="clr-namespace:PixConvert"
    xmlns:ui="http://schemas.modernwpf.com/2019">

    <Application.Resources>
        <ResourceDictionary>
            <!-- App : Global_Merged_Dictionaries -->
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
                <ResourceDictionary Source="Themes/Generic.xaml" />
                <ResourceDictionary Source="Resources/Languages/Lang.Serilog.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- App : Global_Converters -->
            <converters:UpperCaseConverter x:Key="UpperCaseConverter" />
            <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <SolidColorBrush x:Key="DialogWarningForegroundBrush" Color="#D97706" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
